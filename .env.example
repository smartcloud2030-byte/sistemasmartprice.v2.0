# ─────────────────────────────────────────
# SmartPrice — Variáveis de Ambiente (VPS)
# ─────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub!

# Domínio principal (sem https://)
DOMAIN=seudominio.com.br

# Banco de dados PostgreSQL
DB_PASSWORD=SUA_SENHA_FORTE_AQUI

# MinIO (armazenamento de imagens)
MINIO_ACCESS_KEY=smartprice_admin
MINIO_SECRET_KEY=SUA_SENHA_MINIO_FORTE_AQUI

# Supabase (manter enquanto não migrar completamente)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx

# Google AI (se usar no app)
VITE_GOOGLE_AI_KEY=AIzaxxxxxxxxxx

# Firebase (se usar no app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Node
NODE_ENV=production
